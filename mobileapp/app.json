{
  "expo": {
    "name": "PlantsPack",
    "slug": "plantspack",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "plantspack",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.plantspack.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PlantsPack needs your location to show nearby vegan places on the map.",
        "NSCameraUsageDescription": "PlantsPack needs camera access for the barcode and ingredient scanners.",
        "NSPhotoLibraryUsageDescription": "PlantsPack needs photo library access to scan ingredient labels.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "21"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#f7f7f3"
      },
      "package": "plantspack.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ],
      "blockedPermissions": [
        "com.google.android.gms.permission.AD_ID",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "plantspack.com",
              "pathPrefix": "/vegan"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "versionCode": 10
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#083510"
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PlantsPack to access your camera for barcode and ingredient scanning."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow PlantsPack to use your location to show nearby vegan places."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f7f7f3"
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2387639f-4faf-4aa3-bbf1-6469e262b321"
      }
    },
    "owner": "papasoft",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2387639f-4faf-4aa3-bbf1-6469e262b321"
    }
  }
}
