.DS_Store
*.pem

# local env files
.env*.local

# Firebase service-account / admin keys (FCM sender key) — NEVER commit these.
# google-services.json IS safe to commit (client config, shipped in the app).
*-adminsdk-*.json
*service-account*.json
firebase-service-account*.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
.env
