# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing artifacts (keep test source files for deployment)
/coverage
/playwright-report/
/test-results/
playwright-report/
test-results/
playwright/.cache/
.playwright/
test-output/
screenshots/
videos/
traces/
downloads/
# Test build artifacts
*.spec.js.map
*.test.js.map
# Test media files (but keep test source code)
test-results/**/*.png
test-results/**/*.webm  
test-results/**/*.mp4
playwright-report/**/*.png
playwright-report/**/*.webm
playwright-report/**/*.mp4
# But keep source images in public and src
!/public/**/*.png
!/public/**/*.jpg
!/public/**/*.jpeg
!/public/**/*.gif
!/public/**/*.svg
!/src/**/*.png
!/src/**/*.jpg
!/src/**/*.jpeg
# Keep all test source files for deployment
!/tests/**/*.ts
!/tests/**/*.js
!playwright.config.ts
!playwright.config.ci.ts

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# Sentry Config File
.env.sentry-build-plugin
.claude/settings.local.json

# Scraper data, import scripts, and DB details (keep out of repo)
scripts/*.json
scripts/*.log
scripts/data/
scripts/scrape-*.js
scripts/scrape-*.ts
scripts/import-*.ts
scripts/import-*.js
scripts/enrich-*.ts
scripts/enrich-*.js
scripts/translate-*.ts
scripts/transliterate-*.ts
scripts/fetch-*.ts
scripts/batch-scan-*.ts
scripts/check-rls.ts
scripts/osm-*.json
scripts/db-backup-*.json
scripts/cities-from-db.json
osm-*.json

# External data dumps (license-limited or large) and debug logs
/data/
/logs/

# Local notes / scratch files
backlinks-catalog.html

# Local-only scratch scripts (started with _) — used for one-off DB
# audits, dedup runs, smoke tests. Never meant to ship.
scripts/_*.ts
scripts/_*.js

# Local-only reference docs moved out of the public repo root
# (commit 2026-05-11). Kept on disk under docs/ for personal reference;
# never tracked.
docs/ANALYTICS.md
docs/AUTH_SETUP.md
docs/AUTH_TESTING_GUIDE.md
docs/CUSTOM_GPT_SETUP.md
docs/EMAIL_CONFIRMATION_SETUP.md
docs/HOW_TO_VIEW_WEBHOOK_LOGS.md
docs/NOTIFICATION_SYSTEM.md
docs/OPENAI_SECURITY.md
docs/PACKS_FEATURE_PLAN.md
docs/SUPABASE_AUTH_CONFIG.md
docs/UPTIME_MONITORING.md

# Scrape outputs and audit run logs - kept on disk for local analysis but
# never tracked. Re-added 2026-05-22 after a sweeping commit caught them.
scripts/seo-out/
GSC/
summer/
reports/*.csv
reports/*.jsonl
reports/*.log

# Claude Code worktrees - they may contain embedded git repos
.claude/worktrees/

# Root-level run logs from batch scripts
/be-nl-followup.log
/fix-null-cities.log
/osm-import.log
