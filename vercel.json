{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/backup/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/verify-places/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/osm-sync/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/backup",
      "schedule": "17 3 * * *"
    },
    {
      "path": "/api/cron/verify-places",
      "schedule": "23 */6 * * *"
    },
    {
      "path": "/api/cron/osm-sync",
      "schedule": "0 5 * * 0"
    }
  ]
}
