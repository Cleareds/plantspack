{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "src/app/sitemap/priority.xml/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/sitemap/content.xml/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/sitemap/thin.xml/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/sitemap/dishes.xml/route.ts": {
      "maxDuration": 90,
      "memory": 1024
    },
    "src/app/sitemap-index.xml/route.ts": {
      "maxDuration": 10,
      "memory": 512
    },
    "src/app/api/cron/backup/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/cron/verify-places/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/cron/osm-sync/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/cron/refresh-scores/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-scores",
      "schedule": "17 3 * * *"
    }
  ]
}
